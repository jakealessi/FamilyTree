# --- Database (required on Vercel / production hosts) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Neon / pooled Postgres: use a direct (non-pooled) URL for migrations during build.
# The `vercel-build` script runs: DATABASE_URL="${DIRECT_URL:-$DATABASE_URL}" prisma migrate deploy
# Set DIRECT_URL to your direct connection string; keep DATABASE_URL as the pooled URL for the app runtime.
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Only needed for `prisma migrate dev` locally (shadow database).
# SHADOW_DATABASE_URL="postgresql://..."

# --- Optional ops / security ---
# Shared secret for POST /api/trees/[slug]/reactivate with { "adminRecoveryToken": "..." } when the tree is archived.
# ADMIN_RECOVERY_TOKEN=""

# Max upload size for person media (bytes). Defaults to app constant if unset.
# MAX_UPLOAD_SIZE_BYTES=5242880

# Login & register: max attempts per IP per window (separate buckets for login vs register).
# RATE_LIMIT_AUTH_MAX=30
# RATE_LIMIT_AUTH_WINDOW_MS=900000
